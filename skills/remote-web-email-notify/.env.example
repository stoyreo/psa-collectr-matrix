# ──────────────────────────────────────────────────────────────
#  remote-web-email-notify — environment config
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env` at your PROJECT ROOT (not inside the skill folder)
# and fill in the blanks. Never commit the real .env to git.

# ── REQUIRED ──────────────────────────────────────────────────

# Gmail App Password (16 chars, no spaces).
# Generate at: https://myaccount.google.com/apppasswords
#   1. Sign in as the Gmail account that will SEND the email
#   2. App name: e.g. "Tunnel Notifier"  →  Create
#   3. Copy the 16-char password here
GMAIL_APP_PASSWORD=

# The Gmail address the App Password belongs to.
# This is the "From:" address on outgoing emails.
EMAIL_SENDER=techcraftlab.bkk@gmail.com

# Comma-separated list of people who should receive the "dashboard is live" email.
EMAIL_RECIPIENTS=you@example.com,teammate@example.com

# ── OPTIONAL (branding) ───────────────────────────────────────

# Shown in the email subject line and the card header.
PROJECT_NAME=My Awesome Dashboard

# Shown next to the project name. Any emoji works.
PROJECT_EMOJI=🚀
